{
  "name": "@pulseboard/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:demo": "tsx src/dev-server.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@pulseboard/shared": "workspace:*",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.0",
    "fractional-indexing": "^3.2.0",
    "jose": "^6.0.10",
    "pg": "^8.16.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.1.0"
  }
}
