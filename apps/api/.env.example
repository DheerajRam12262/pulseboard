# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Postgres connection string (Neon, Supabase, or local docker-compose)
DATABASE_URL=postgres://pulseboard:pulseboard@localhost:5432/pulseboard

# Secret used to sign access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-64-char-hex-string-change-me-to-a-64-char-hex

# Frontend origin allowed by CORS (comma-separated for multiple)
WEB_ORIGIN=http://localhost:3000

# Set to "true" in production (cross-site cookies require Secure + SameSite=None)
COOKIE_SECURE=false
